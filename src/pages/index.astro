---
import { HeroSection } from '../components/HeroSection';
import { ProblemSection } from '../components/ProblemSection';
import { Slide3Diagram } from '../components/Slide3Diagram';
import { InvestorSections } from '../components/InvestorSections';
import '../styles/global.css';

const navItems = [
	{ href: '#problem', label: 'Problem' },
	{ href: '#rozwiazanie', label: 'Rozwiązanie' },
	{ href: '#model', label: 'Model' },
	{ href: '#finanse', label: 'Finanse' },
	{ href: '#impact', label: 'Impact' },
];

const contacts = [
	{ name: 'Katarzyna Sadowska', phone: '+48 691 179 270' },
	{ name: 'Paulina Pawlak', phone: '+48 694 831 130' },
	{ name: 'Joanna Michalska', phone: '+48 607 236 616' },
	{ name: 'Magdalena Boratyńska-Soral', phone: '+48 601 368 359' },
	{ name: 'Aldona Tulikowska-Chwalisz', phone: '+48 662 621 121' },
];
---

<!doctype html>
<html lang="pl" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="RegioODzysk: regionalny hub odzysku zasobów dla ścieków przemysłu FMCG. Model infrastrukturalny, finansowanie, ESG i skalowanie."
		/>
		<title>RegioODzysk | Regionalny hub odzysku zasobów dla FMCG</title>
	</head>
	<body class="bg-white text-gray-900 antialiased">
		<nav class="fixed inset-x-0 top-0 z-50 border-b border-gray-200 bg-white/95 backdrop-blur-xl">
			<div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
				<a href="#" class="flex items-center gap-3" aria-label="RegioODzysk - strona główna">
					<span class="brand-mark" aria-hidden="true">
						<svg viewBox="0 0 48 48" class="h-7 w-7">
							<path d="M22.7 7.5c7.6 8.7 11.4 15.1 11.4 22.1 0 8-5.2 13.5-12.4 13.5S9.3 37.6 9.3 29.6c0-7 5.1-14.7 13.4-22.1Z" fill="#0ea5e9"></path>
							<path d="M30.2 15.9c5.9.6 10.2 3.9 11.9 9.1-7.3-.2-12.8 2.5-16.4 8.1-1.9-5.7-.4-11.6 4.5-17.2Z" fill="#16a34a"></path>
							<path d="M17.5 36.2c6.9 1.2 13.2-2.5 18.9-11.2" fill="none" stroke="#ffffff" stroke-linecap="round" stroke-width="3"></path>
						</svg>
					</span>
					<span class="text-xl font-black tracking-normal text-brand-dark">
						Regio<span class="text-brand-green">ODzysk</span>
					</span>
				</a>

				<div class="hidden items-center gap-7 lg:flex">
					{navItems.map((item) => (
						<a href={item.href} class="text-sm font-bold text-gray-600 transition-colors hover:text-brand-blue-dark">
							{item.label}
						</a>
					))}
				</div>

				<a
					href="#kontakt"
					class="hidden rounded-md bg-brand-dark px-5 py-2.5 text-sm font-bold text-white transition-colors hover:bg-brand-blue-dark focus:outline-none focus:ring-2 focus:ring-brand-blue/40 sm:inline-flex"
				>
					Kontakt
				</a>
			</div>
		</nav>

		<main>
			<HeroSection client:load />
			<ProblemSection client:visible />

			<section id="rozwiazanie" class="overflow-hidden border-y border-gray-100 bg-white py-20 sm:py-24">
				<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
					<div class="mx-auto max-w-3xl text-center">
						<p class="section-kicker justify-center">Rozwiązanie</p>
						<h2 class="mt-3 text-3xl font-black leading-tight text-brand-dark sm:text-4xl">
							RegioODzysk zamienia liniowy koszt ściekowy w regionalny obieg wartości.
						</h2>
						<p class="mt-4 text-base leading-8 text-gray-600">
							Hub odbiera strumienie ścieków lub osadów od zakładów FMCG, przetwarza je w wyspecjalizowanej instalacji i oddaje na rynek wodę technologiczną, energię, surowce oraz dane compliance.
						</p>
					</div>

					<div class="mt-12">
						<Slide3Diagram client:visible />
					</div>
				</div>
			</section>

			<InvestorSections client:visible />
		</main>

		<footer id="kontakt" class="border-t border-gray-200 bg-white py-12">
			<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
				<div class="grid gap-10 lg:grid-cols-[1.1fr_1.4fr] lg:items-start">
					<div>
						<div class="flex items-center gap-3">
							<span class="brand-mark" aria-hidden="true">
								<svg viewBox="0 0 48 48" class="h-7 w-7">
									<path d="M22.7 7.5c7.6 8.7 11.4 15.1 11.4 22.1 0 8-5.2 13.5-12.4 13.5S9.3 37.6 9.3 29.6c0-7 5.1-14.7 13.4-22.1Z" fill="#0ea5e9"></path>
									<path d="M30.2 15.9c5.9.6 10.2 3.9 11.9 9.1-7.3-.2-12.8 2.5-16.4 8.1-1.9-5.7-.4-11.6 4.5-17.2Z" fill="#16a34a"></path>
									<path d="M17.5 36.2c6.9 1.2 13.2-2.5 18.9-11.2" fill="none" stroke="#ffffff" stroke-linecap="round" stroke-width="3"></path>
								</svg>
							</span>
							<span class="text-xl font-black text-brand-dark">Regio<span class="text-brand-green">ODzysk</span></span>
						</div>
						<p class="mt-5 max-w-md text-sm leading-7 text-gray-600">
							Ścieki przemysłu FMCG w centrum cyrkularności. Model regionalnego odzysku zasobów, zaprojektowany pod problem, finansowanie i mierzalny impact.
						</p>
					</div>

					<div>
						<h2 class="text-lg font-black text-brand-dark">Zapraszamy do kontaktu</h2>
						<div class="mt-5 grid gap-3 sm:grid-cols-2">
							{contacts.map((contact) => (
								<a
									href={`tel:${contact.phone.replaceAll(' ', '')}`}
									class="rounded-lg border border-gray-200 bg-brand-paper px-4 py-3 transition hover:border-brand-blue/40 hover:bg-white"
								>
									<span class="block text-sm font-black text-brand-dark">{contact.name}</span>
									<span class="mt-1 block text-sm font-semibold text-brand-blue-dark">{contact.phone}</span>
								</a>
							))}
						</div>
					</div>
				</div>

				<div class="mt-10 flex flex-col gap-3 border-t border-gray-200 pt-6 text-xs font-semibold text-gray-500 sm:flex-row sm:items-center sm:justify-between">
					<p>© {new Date().getFullYear()} RegioODzysk. Opracowanie na podstawie koncepcji projektowej.</p>
					<p>Akademia Leona Koźmińskiego · Warszawa · 30 maja 2026</p>
				</div>
			</div>
		</footer>
	</body>
</html>
